# Hospital Simulation — Environment Variables
# Copy to .env and fill in your values:  cp .env.example .env

# Anthropic API key (required for LLM features; mock engine works without it)
ANTHROPIC_API_KEY=sk-ant-...

# LLM model to use (fast + cheap for hackathon)
LLM_MODEL=claude-haiku-4-5-20251001

# Simulation timing
TICK_INTERVAL_SECONDS=1.0

# Hospital capacity
MAX_BEDS_GENERAL=20
MAX_BEDS_ICU=5
INITIAL_DOCTORS=4

# Patient arrival rate (mean patients per tick, Poisson distributed)
ARRIVAL_RATE_PER_TICK=1.5

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
